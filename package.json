{
	"name": "s3pia",
	"module": "src/index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"start": "bun run src/index.ts",
		"cli": "bun run src/cli/index.ts",
		"gateway": "bun run src/gateway/index.ts",
		"docker:up": "bun run --cwd frontend build && docker-compose up -d --build",
		"docker:down": "docker-compose down",
		"docker:clean": "docker-compose down -v",
		"docker:logs": "docker logs s3pia -f",
		"docker:shell": "docker-compose exec s3pia sh",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"format": "biome format .",
		"format:fix": "biome format --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.13",
		"@types/bun": "latest"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^3.0.45",
		"@ai-sdk/deepseek": "^2.0.20",
		"@ai-sdk/google": "^3.0.29",
		"@ai-sdk/groq": "^3.0.24",
		"@ai-sdk/openai": "^3.0.29",
		"@codemirror/commands": "6",
		"@codemirror/theme-one-dark": "^6.1.3",
		"@codemirror/view": "6",
		"@openrouter/ai-sdk-provider": "^2.2.3",
		"ai": "^6.0.90",
		"codemirror": "6",
		"zhipu-ai-provider": "^0.2.2",
		"zod": "^3.25.76"
	}
}
